# PostgreSQL connection string. Use the pooled connection string from Supabase/Render/Neon in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suno_markup_studio"

# Comma-separated list of allowed frontend origins for credentialed CORS.
# Local example:
WEB_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
# Production example:
# WEB_ORIGINS="https://your-suno-app.vercel.app,https://your-preview.vercel.app"

PORT="8787"
HOST="0.0.0.0"

# For Vercel frontend + Render API on different domains use SameSite=None and Secure cookies.
# In production these are the defaults; keep explicit values in the hosting dashboard for clarity.
COOKIE_SECURE="false"
COOKIE_SAME_SITE="lax"

# Optional. Usually leave empty. Set only when API and web share a parent custom domain.
# COOKIE_DOMAIN=".example.com"

ACCESS_TOKEN_TTL_MS="900000"
REFRESH_TOKEN_TTL_MS="2592000000"
