# Leave empty when Vite dev proxy or Vercel same-origin proxy is used.
# Recommended for Vercel: keep empty and set API_PROXY_TARGET_ORIGIN in Vercel.
# Set to the public Render API origin only for direct browser calls:
# VITE_API_BASE_URL="https://your-suno-api.onrender.com"
VITE_API_BASE_URL=""

# Disable backend auth probing for frontend-only screenshots/e2e.
VITE_AUTH_PROBE="false"
