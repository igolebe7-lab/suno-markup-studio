# Leave empty when Vite dev proxy or Vercel rewrites are used.
# Recommended for Vercel: keep empty and proxy /api through vercel.json.
# Set to the public Render API origin for direct browser calls:
# VITE_API_BASE_URL="https://your-suno-api.onrender.com"
VITE_API_BASE_URL=""

# Disable backend auth probing for frontend-only screenshots/e2e.
VITE_AUTH_PROBE="false"
